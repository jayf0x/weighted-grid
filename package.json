{
  "name": "weighted-grid",
  "version": "1.0.3",
  "type": "module",
  "description": "A zero-dependency, weight-driven grid that fills its container using a squarified treemap, agnostic to what's inside each cell.",
  "author": "jayF0x",
  "license": "MIT",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:run": "bun test",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "demo:dev": "cd demo && bun install && bun run dev",
    "demo:deploy": "bash ./scripts/deploy-pages.sh",
    "npm:bootstrap": "bash ./scripts/bootstrap-npm.sh",
    "npm:deploy": "bash ./scripts/publish-npm.sh",
    "size": "size-limit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@size-limit/file": "^11",
    "@types/react": "^19.2.17",
    "bun-types": "^1.3.14",
    "byte-snap": "^1.1.3",
    "plugin-include": "^1.0.2",
    "react": "^19",
    "size-limit": "^11",
    "typescript": "^5.6.0",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "6 kB"
    }
  ],
  "keywords": [
    "react",
    "grid",
    "treemap",
    "squarified-treemap",
    "layout-algorithm",
    "weighted-layout",
    "responsive-grid",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayf0x/weighted-grid.git"
  },
  "homepage": "https://github.com/jayf0x/weighted-grid#readme",
  "bugs": {
    "url": "https://github.com/jayf0x/weighted-grid/issues"
  }
}
