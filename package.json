{
  "name": "rect-pack",
  "version": "0.1.0",
  "type": "module",
  "description": "A high-performance TypeScript library for 2D rectangle packing — area-based packing and Guillotine bin packing with multiple heuristics for optimal space utilization.",
  "author": "jayF0x",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:run": "bun test",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "demo:dev": "cd demo && bun install && bun run dev",
    "npm:deploy": "bash ./scripts/publish-npm.sh",
    "size": "size-limit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@size-limit/file": "^11",
    "@types/react": "^19.2.17",
    "bun-types": "^1.3.14",
    "size-limit": "^11",
    "typescript": "^5.6.0",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "6 kB"
    }
  ],
  "keywords": [
    "rectangle-packer",
    "rectangle-packing",
    "2d-packing",
    "bin-packing",
    "guillotine-packing",
    "space-optimization",
    "layout-algorithm",
    "texture-packing",
    "sprite-packing",
    "atlas-generation",
    "packing-algorithm",
    "typescript",
    "algorithm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayf0x/rect-pack.git"
  },
  "homepage": "https://github.com/jayf0x/rect-pack#readme",
  "bugs": {
    "url": "https://github.com/jayf0x/rect-pack/issues"
  }
}
